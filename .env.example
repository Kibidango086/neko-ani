# Backend API Configuration
# In Vercel, this should be relative '/api' or the full deployment URL
VITE_API_URL=/api

# Browserless Configuration (Optional but recommended for complex sites)
# Connection string for browserless.io or self-hosted instance
# Example: wss://chrome.browserless.io?token=YOUR-API-TOKEN
BROWSERLESS_URL=

# Remote Video Extraction Server (Optional Fallback)
# The URL of a secondary external service if local/browserless extraction fails
REMOTE_EXTRACT_API_URL=https://example.com/api/extract-video
