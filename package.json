{
  "name": "neko-ani",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx server/index.ts",
    "dev:client": "vite",
    "build": "vite build",
    "vercel-build": "vite build",
    "download-browsers": "npx playwright install chromium",
    "build:server": "tsc server/index.ts server/parsers.ts --outDir dist/server --module es2020 --target es2020 --moduleResolution node --esModuleInterop true",
    "preview": "vite preview",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "framer-motion": "^12.23.24",
    "hls.js": "^1.6.15",
    "jsdom": "^23.0.1",
    "lucide-react": "^0.555.0",
    "node-fetch": "^3.3.2",
    "playwright-core": "^1.48.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsdom": "^21.1.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.7.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
